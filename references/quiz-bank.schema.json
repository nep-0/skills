{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/quiz-bank.schema.json",
  "title": "Quiz Question Bank",
  "description": "Question bank format for practice exams with sections, scoring rules, and progress-friendly metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bankId",
    "title",
    "version",
    "locale",
    "questionTypes",
    "questions"
  ],
  "properties": {
    "bankId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "subject": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "questionTypes": {
      "type": "object",
      "description": "Default scoring per question type.",
      "additionalProperties": false,
      "required": [
        "single_choice",
        "multiple_choice",
        "true_false"
      ],
      "properties": {
        "single_choice": {
          "$ref": "#/$defs/typeRule"
        },
        "multiple_choice": {
          "$ref": "#/$defs/typeRule"
        },
        "true_false": {
          "$ref": "#/$defs/typeRule"
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "typeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "defaultPoints"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "defaultPoints": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "questionIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "type",
        "prompt",
        "options",
        "answer"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "sectionId": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "single_choice",
            "multiple_choice",
            "true_false"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "stem": {
          "type": "string"
        },
        "points": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "importType": {
              "type": "string"
            },
            "origin": {
              "type": "string"
            },
            "chapter": {
              "type": "string"
            }
          }
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "answer": {
          "$ref": "#/$defs/answer"
        },
        "explanation": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "true_false"
              }
            }
          },
          "then": {
            "properties": {
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctOptionIds"
      ],
      "properties": {
        "correctOptionIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
